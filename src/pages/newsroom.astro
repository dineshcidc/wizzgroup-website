---
import Header from "../components/Header.astro";
import Footer from "../components/MainFooter.astro";
import PageAnimations from "../components/PageAnimations.astro";
import KnowledgeCard from "../components/KnowledgeCard.astro";
import banner from "../assets/ApplicationBanner.png";
import logo from "../assets/Wizzlogo.png";

import blog1 from "../assets/Blog1.png";
import blog2 from "../assets/Blog2.png";
import blog3 from "../assets/Blog3.png";
import blog4 from "../assets/Blog4.png";
import blog5 from "../assets/Blog5.png";
import blog6 from "../assets/Blog6.png";

import "../styles/global.css";

const tabs = [
  { label: "Press Releases", selected: true },
  { label: "Media Coverage", selected: false },
];

const cards = [
  {
    image: blog1,
    date: "Last updated: December 2025",
    title: "Wizz Financial celebrates Iftar",
    description:
      "Iftar, the daily evening meal used to break the fast during Ramadan, is a deeply meaningful cultural and spiritual occasion, bringing people together in reflection and gratitude. This year, we were delighted to host a number of Iftar events across Africa and the UAE, creating opportunities to give back and connect with the communities around us.",
    category: "Press Releases",
  },
  {
    image: blog2,
    date: "Last updated: December 2025",
    title: "Wizz Financial Completes First Stablecoin-Powered Cross-Border Transaction from the US to 80 Countries with BitGo",
    description:
      "Milestone marks the next phase of Wizz Financial's multi-product fintech platform, extending its Wizz CrossBorder USA capabilities into blockchain-based B2B and B2C payments.",
    category: "Press Releases",
  },
  {
    image: blog3,
    date: "Last updated: December 2025",
    title: "Wizz Financial and BitGo Team on X-Border Stablecoin Payments",
    description:
      "FinTech Wizz Financial achieved a company milestone for cross-border transactions. Wizz completed its first stablecoin-powered cross-border remittance and treasury transaction originating from the United States, with capabilities into 80 countries.",
    category: "Press Releases",
  },
  {
    image: blog4,
    date: "Last updated: December 2025",
    title: "The Perfect Travel Match: Wizzmoni partners with KL Rahul & Athiya Shetty",
    description:
      "Wizzmoni, formerly Unimoni, has officially appointed Indian cricketer KL Rahul and Bollywood actor Athiya Shetty as the faces of its premium Wizz Voyager Multi-Currency Travel Card and foreign exchange solutions.",
    category: "Media Coverage",
  },
  {
    image: blog5,
    date: "Last updated: December 2025",
    title: "Wizzmoni opens its 320th branch, located in Nalgonda",
    description:
      "Wizzmoni (formerly Unimoni), one of India's most trusted and diversified NBFCs, inaugurated its 320th branch in Telangana's Nalgonda, reinforcing its nationwide footprint and commitment to accessible financial services.",
    category: "Media Coverage",
  },
  {
    image: blog6,
    date: "Last updated: December 2025",
    title: "Wizz Financial Completes First Stablecoin-Powered Cross-Border Transaction from the US to 80 Countries with BitGo",
    description:
      "Milestone marks the next phase of Wizz Financial's multi-product fintech platform, extending its Wizz CrossBorder USA capabilities into blockchain-based B2B and B2C payments.",
    category: "Media Coverage",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logo.src} />
    <title>Newsroom</title>
    <style define:vars={{ bannerSrc: `url('${banner.src}')` }}>
      .hero-bg {
        background-image: var(--bannerSrc);
      }
    </style>
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <div
      class="hero-bg relative min-h-screen w-full bg-cover bg-center bg-no-repeat"
    >
      <div class="absolute inset-0 bg-[#12152F]/50"></div>

      <div
        class="relative z-10 flex flex-col justify-between gap-10 sm:gap-14 md:gap-24 lg:gap-34 p-5 sm:p-8 md:p-10 lg:p-12 min-h-screen"
      >
        <!-- Header -->
        <div class="opacity-0" data-animate="fade-up" data-delay="100">
          <Header />
        </div>

        <!-- Hero Title Section -->
        <div
          class="opacity-0 flex flex-col items-center gap-6 text-center"
          data-animate="fade-up"
          data-delay="200"
        >
          <h1
            class="text-white font-bold text-xl sm:text-3xl md:text-5xl lg:text-5xl"
          >
            Newsroom
          </h1>

          <div class="flex flex-col gap-5 max-w-4xl">
            <p class="text-white/70 text-center leading-relaxed text-sm sm:text-base md:text-xl">
              Stay up to date with the latest news, announcements, and media coverage from Wizz Financial.
            </p>
            <p class="text-white/70 text-center leading-relaxed text-sm sm:text-base md:text-xl">
              Our newsroom highlights important milestones, launches, strategic partnerships that reflect our commitment to expanding secure and accessible financial services.
            </p>
          </div>
        </div>

        <!-- Tabs + Cards Section -->
        <div
          class="opacity-0 flex flex-col gap-14"
          data-animate="fade-up"
          data-delay="300"
        >
          <!-- Tabs -->
          <div class="flex flex-wrap items-center justify-center gap-3">
            {tabs.map((tab) => (
              <div
                class={`newsroom-tab px-6 py-2 rounded-full text-sm sm:text-base w-fit transition-all duration-300 cursor-pointer border
                ${tab.selected
                  ? "bg-[#FFBD00]/17 border-[#F79A59] text-white"
                  : "bg-[#8A8A8A]/10 text-white hover:bg-white/10 border-transparent"
                }`}
                data-category={tab.label}
              >
                {tab.label}
              </div>
            ))}
          </div>

          <!-- Cards Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="newsroom-grid">
            {cards.map((card) => (
              <div class="newsroom-card" data-category={card.category}>
                <KnowledgeCard
                  image={card.image}
                  date={card.date}
                  title={card.title}
                  description={card.description}
                  href="/newsroom-detail"
                />
              </div>
            ))}
          </div>
        </div>

        <!-- Footer -->
        <div class="opacity-0" data-animate="fade-up" data-delay="400">
          <Footer />
        </div>
      </div>
    </div>

    <PageAnimations />

    <script>
      function setupNewsroomTabs() {
        const tabs = document.querySelectorAll<HTMLElement>(".newsroom-tab");
        const cardButtons = document.querySelectorAll<HTMLElement>("#newsroom-grid .newsroom-card a span");

        function setButtonText(text: string) {
          cardButtons.forEach((span) => {
            span.textContent = text;
          });
        }

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            tabs.forEach((t) => {
              t.classList.remove("bg-[#FFBD00]/17", "border-[#F79A59]");
              t.classList.add("bg-[#8A8A8A]/10", "border-transparent");
            });
            tab.classList.remove("bg-[#8A8A8A]/10", "border-transparent");
            tab.classList.add("bg-[#FFBD00]/17", "border-[#F79A59]");

            const label = tab.dataset.category ?? "";
            setButtonText(label === "Media Coverage" ? "View Article" : "Read More");
          });
        });
      }

      setupNewsroomTabs();
    </script>
  </body>
</html>
