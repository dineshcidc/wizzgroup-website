---
import "../styles/global.css";
import LogoCard from "../components/LogoCard.astro";
import PageAnimations from "../components/PageAnimations.astro";
import Carousel from "../components/Carousel.astro";
import VideoBackground from "../components/VideoBackground.astro";
import mapdots from "../assets/Mapdots.png";
import slide1 from "../assets/Slide_1.png";
import corridorMap from "../assets/CorridorMap.png";
import slide3 from "../assets/Slide_3.png";
import crossborder from "../assets/Crossborder.png";
import migrant from "../assets/Migrant.png";
import whitecoller from "../assets/Whitecoller.png";
import bankfintech from "../assets/Bankfintech.png";
import smecorparate from "../assets/Smecorparate.png";
import logo from "../assets/Wizzlogo.png";

const stats = [
  { value: "5Mn+",   label: "Customers" },
  { value: "50+",    label: "Regulatory Licences" },
  { value: "500+",   label: "Physical Branches" },
  { value: "159",    label: "Countries Payout Network" },
  { value: "$6.9Bn", label: "Transaction Volumes*" },
];

// Extend this array to add more carousel slides
const slides = [
  {
    title: "The Only Platform Focusing on GCC, INDIA, SEA & US Corridors",
    p2: "Wizz Financial connects cross-border payments, digital wallets, card issuing, secured lending, and stablecoin treasury on a single regulated infrastructure — built for the corridors that matter most.",
    fgImage: slide1.src,
    mobileFgImage: corridorMap.src,
    fgAlt: "Wizz platform visualization",
  },
  {
    title: "Serving Every Cross-Border Customer",
    p2: "Legacy systems break across borders — creating friction, delays, and high costs for global customers. Wizz Financial solves this with an integrated financial stack built specifically for cross-border scale.",
    bgImage: mapdots.src,
    fgImage: "",
    fgAlt: "",
    fgScale: "",
    cards: [
      { image: crossborder.src,  label: "Cross Border Families", style: "top:1%;left:5%"   },
      { image: migrant.src,      label: "Migrant workers",       style: "top:32%;left:36%" },
      { image: whitecoller.src,  label: "White Collar Expats",   style: "top:3%;right:3%"  },
      { image: bankfintech.src,  label: "Banks & Fintechs",      style: "top:70%;left:8%"  },
      { image: smecorparate.src, label: "SME & Corporates",      style: "top:65%;right:3%" },
    ],
  },
  {
    title: "The Financial Operating System for Cross-Border Populations",
    p2: "Wizz Financial is a regulated financial ecosystem with licensed credibility across the GCC, India, South East Asia, and the US.",
    bgImage: mapdots.src,
    fgImage: slide3.src,
    fgAlt: "Wizz platform layers",
    fgScale: "scale-100",
    listItems: [
      {
        title: "Core Platform",
        subtitle: "Zero Assumption | Cloud-native | API Gateway",
      },
      {
        title: "Treasury",
        subtitle: "Stable coin-backed Treasury Bypass | Traditional Treasury",
      },
      {
        title: "Processing Engine",
        subtitle:
          "Processing Engine | KYC | KYB | KYBC | KYT | AML | AI/ML | Authentication & Authorisation for VISA & Mastercard",
      },
      {
        title: "Connectivity",
        subtitle: "Bank APIs | Payment Networks | External Services",
      },
      {
        title: "Distribution",
        subtitle:
          "B2C: Wallet, Card, Stablecoin, Agents, Branch, Kiosk | B2B APIs, FIs",
      },
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logo.src} />
    <title>Landing Page</title>
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <div class="relative min-h-screen w-full">
      <VideoBackground overlayOpacity="80" />

      <div
        class="relative z-10 flex flex-col justify-between gap-8 sm:gap-10 lg:gap-0 p-5 sm:p-8 md:p-10 lg:p-12 min-h-screen"
      >
        <!-- Sub-header -->
        <div
          class="opacity-0 hidden lg:flex flex-col gap-5 h-fit sm:flex-row sm:justify-between sm:items-center"
          data-animate="fade-up"
          data-delay="100"
        >
          <LogoCard />
          <a
            href="/dashboard"
            class="flex items-center text-lg justify-center gap-2 whitespace-nowrap cursor-pointer
      font-medium text-white bg-[#4D4222]/25 border border-white/10
      w-60 h-16 rounded-[2.5rem]"
          >
            Explore WIZZ

            <svg
              class="w-4 h-4"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M6 3L11 8L6 13"
                stroke="white"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>

        <!-- Carousel -->
        <div
          id="carousel"
          class="opacity-0 relative"
          data-animate="fade-up"
          data-delay="300"
        >
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 sm:gap-6 md:gap-8 lg:gap-12 items-center">
            <!-- Left: per-slide text panels, absolutely stacked -->
            <div
              class="lg:col-span-6 grid"
            >
              {
                slides.map((slide, i) => (
                  <div
                    class={`carousel-slide col-start-1 row-start-1 h-fit flex flex-col lg:flex-row gap-3 lg:gap-4 xl:gap-6 items-start transition-opacity duration-300 ease-out ${i === 0 ? "opacity-100" : "opacity-0 pointer-events-none"}`}
                    data-slide={i}
                  >
                    <!-- Gold border: horizontal pill at top on mobile, vertical bar on left on desktop -->
                    <div
                      class="shrink-0  bg-linear-to-b from-[#F6AF27] to-[#CA7D0F]
                      h-1 w-full
                      sm:h-1.5 sm:w-full
                      lg:h-auto lg:w-3 lg:self-stretch
                      xl:w-3.5
                      2xl:w-4"
                    />

                    <div
                      data-left-card
                      class="flex-1 bg-[#373737]/30 border border-white/10 rounded-3xl
                    p-3 sm:p-4 md:p-5 lg:p-6 xl:p-8 overflow-hidden"
                    >
                      <h2
                        class="text-white font-bold leading-tight mb-3 sm:mb-4 md:mb-5 lg:mb-6
                        text-3xl md:text-4xl lg:text-3xl xl:text-5xl 2xl:text-5xl"
                      >
                        {slide.title}
                      </h2>
                      <div>
                        <p
                          class="text-[#CBCBCB] font-normal leading-snug
                          text-sm md:text-base xl:text-2xl 2xl:text-2xl"
                        >
                          {slide.p2}
                        </p>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- Right: per-slide content (slide 1 = Slide_1 only, others = mapdots + overlays) -->
            <div class="lg:col-span-6 relative overflow-hidden min-h-[380px] sm:min-h-[440px] md:min-h-[420px] lg:min-h-[480px] xl:min-h-[540px]">
              {
                slides.map((slide, i) =>
                  "cards" in slide ? (
                    <div
                      data-fg={i}
                      class={`absolute inset-0 w-full h-full transition-opacity duration-300 ease-out
                      ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      <img
                        src={mapdots.src}
                        alt=""
                        aria-hidden="true"
                        class="absolute inset-0 w-full h-full object-cover"
                      />

                      {/* Mobile & tablet: 2-1-2 structured rows */}
                      <div class="lg:hidden relative z-10 flex flex-col justify-around h-full px-4 sm:px-6 py-4 gap-2">
                        <div class="flex justify-between gap-3">
                          {([slide.cards![0], slide.cards![2]] as {image:string;label:string;style:string}[]).map((card) => (
                            <div class="w-[45%] md:w-fit flex flex-col items-center gap-2 rounded-2xl bg-[#373737]/20 backdrop-blur-xl border border-white/15 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_8px_32px_rgba(0,0,0,0.4)] p-3 sm:p-4">
                              <img src={card.image} alt={card.label} class="w-full h-14 sm:h-18 object-contain" />
                              <span class="text-white text-[10px] sm:text-xs text-center leading-none font-medium">{card.label}</span>
                            </div>
                          ))}
                        </div>
                        <div class="flex justify-center">
                          <div class="w-[45%] md:w-fit flex flex-col items-center gap-2 rounded-2xl bg-[#373737]/20 backdrop-blur-xl border border-white/15 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_8px_32px_rgba(0,0,0,0.4)] p-3 sm:p-4">
                            <img src={slide.cards![1].image} alt={slide.cards![1].label} class="w-full h-14 sm:h-18 object-contain" />
                            <span class="text-white text-[10px] sm:text-xs text-center leading-none font-medium">{slide.cards![1].label}</span>
                          </div>
                        </div>
                        <div class="flex justify-between gap-3">
                          {([slide.cards![3], slide.cards![4]] as {image:string;label:string;style:string}[]).map((card) => (
                            <div class="w-[45%] md:w-fit flex flex-col items-center gap-2 rounded-2xl bg-[#373737]/20 backdrop-blur-xl border border-white/15 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_8px_32px_rgba(0,0,0,0.4)] p-3 sm:p-4">
                              <img src={card.image} alt={card.label} class="w-full h-14 sm:h-18 object-contain" />
                              <span class="text-white text-[10px] sm:text-xs text-center leading-none font-medium">{card.label}</span>
                            </div>
                          ))}
                        </div>
                      </div>

                      {/* Desktop: absolute positioned over map */}
                      {slide.cards!.map((card: { image: string; label: string; style: string }) => (
                        <div
                          class="hidden lg:flex lg:absolute flex-col items-center gap-2 xl:gap-3 rounded-2xl bg-[#373737]/20 backdrop-blur-xl border border-white/15 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_8px_32px_rgba(0,0,0,0.4)] p-2.5 xl:p-4 w-[28%]"
                          style={card.style}
                        >
                          <img src={card.image} alt={card.label} class="w-full h-16 xl:h-24 object-contain" />
                          <span class="text-white text-xs xl:text-sm text-center leading-none font-medium">{card.label}</span>
                        </div>
                      ))}
                    </div>
                  ) : "listItems" in slide ? (
                    <div
                      data-fg={i}
                      class={`absolute inset-0 w-full h-full z-10 flex flex-col lg:flex-row items-center
                      transition-opacity duration-300 ease-out
                      ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      <img
                        src={mapdots.src}
                        alt=""
                        aria-hidden="true"
                        class="absolute inset-0 w-full h-full object-cover"
                      />
                      <!-- Mobile: row (image left, list right). lg+: row with larger image -->
                      <div class="relative z-10 flex flex-row lg:flex-row items-center w-full h-full gap-1 px-3 sm:px-4 lg:px-0 xl:ml-10">
                        <img
                          src={slide.fgImage}
                          alt={slide.fgAlt}
                          class="xl:w-[280px] w-fit xl:h-[550px] md:h-[420px] h-[180px] object-contain shrink-0"
                        />
                        <div class="flex-1 flex flex-col min-w-0">
                          {slide.listItems!.map(
                            (
                              item: { title: string; subtitle: string },
                              idx: number,
                            ) => (
                              <div
                                data-list-item
                                class={`py-2 sm:py-3 lg:py-2 xl:py-4 ${idx < slide.listItems!.length - 1 ? "border-b border-white/10" : ""}`}
                              >
                                <h3
                                  class="text-white font-bold mb-0.5 text-xs sm:text-sm lg:text-sm xl:text-xl"
                                >
                                  {item.title}
                                </h3>
                                <p
                                  class="text-[#CBCBCB] font-light leading-snug text-[10px] sm:text-xs lg:text-xs xl:text-sm"
                                >
                                  {item.subtitle}
                                </p>
                              </div>
                            ),
                          )}
                        </div>
                      </div>
                    </div>
                  ) : (
                    /* Slide 1: corridor map on mobile, Slide_1 on desktop + stats */
                    <div
                      data-fg={i}
                      class={`absolute inset-0 w-full h-full flex flex-col gap-2 sm:gap-3 transition-opacity duration-300 ease-out
                      ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      {"mobileFgImage" in slide && (
                        <img
                          src={(slide as any).mobileFgImage}
                          alt={slide.fgAlt}
                          class="block lg:hidden w-full object-contain flex-1 min-h-0 max-h-[88%] sm:max-h-[90%] mix-blend-multiply"
                        />
                      )}
                      <img
                        src={slide.fgImage}
                        alt={slide.fgAlt}
                        class="hidden lg:block w-full object-contain flex-1 min-h-0 max-h-[80%]"
                      />
                      <div data-stats class="grid grid-cols-2 min-[480px]:grid-cols-3 sm:grid-cols-5 justify-center sm:justify-start gap-3 shrink-0 mt-10">
                        {stats.map((stat) => (
                          <div class="flex flex-col items-center justify-center gap-0.5 sm:gap-1 bg-[#1c2748]/30 w-full backdrop-blur-sm border border-white/10 rounded-xl px-2 py-4 sm:p-3 lg:p-4">
                            <span class="text-white font-bold text-sm sm:text-base lg:text-lg xl:text-xl text-center">{stat.value}</span>
                            <span class="text-[#CBCBCB] text-[10px] sm:text-xs font-light leading-snug text-center">{stat.label}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  ),
                )
              }
            </div>
          </div>
        </div>

        <!-- Footer: dot indicators + mobile footer -->
        <div
          class="opacity-0 flex flex-col gap-8"
          data-animate="fade-up"
          data-delay="700"
        >
          <!-- Dot navigation (all sizes) -->
          <div class="flex lg:justify-start justify-center">
          <div
            class="flex flex-row items-center gap-2 bg-[#373737]/12 rounded-full p-2"
          >
            <!-- Chevron left -->
            <button
              type="button"
              aria-label="Previous slide"
              data-prev
              class="flex items-center justify-center text-white/70 hover:text-white cursor-pointer border-0 bg-transparent transition-colors duration-200"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M10 3L5 8L10 13"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>

            <!-- Dots -->
            <div
              role="tablist"
              aria-label="Carousel navigation"
              class="flex flex-row items-center gap-2"
            >
              {
                slides.map((_, i) => (
                  <button
                    type="button"
                    role="tab"
                    aria-label={`Go to slide ${i + 1}`}
                    aria-selected={i === 0 ? "true" : "false"}
                    data-dot={i}
                    class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer border-0 ${i === 0 ? "active" : "bg-white/40 hover:bg-white/70"}`}
                    style={i === 0 ? "background-color:#BA7F4A" : ""}
                  />
                ))
              }
            </div>

            <!-- Chevron right -->
            <button
              type="button"
              aria-label="Next slide"
              data-next
              class="flex items-center justify-center text-white/70 hover:text-white cursor-pointer border-0 bg-transparent transition-colors duration-200"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M6 3L11 8L6 13"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
          </div>

          <!-- Mobile footer: copyright + logo + explore (hidden on lg+) -->
          <div class="lg:hidden flex flex-col gap-8">
            <!-- Copyright row -->
            <div class="flex items-center gap-3">
              <span class="text-white/50 text-[11px] sm:text-xs font-light whitespace-nowrap">Wizz Financial All Rights Reserved</span>
              <div class="flex-1 h-px bg-white/20"></div>
              <a href="https://www.linkedin.com" target="_blank" rel="noopener" class="w-8 h-8 sm:w-9 sm:h-9 bg-white rounded-full flex items-center justify-center shrink-0">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="#0A66C2" aria-label="LinkedIn">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
            <!-- Logo + Explore WIZZ row -->
            <div class="flex items-center justify-between gap-3">
              <a href="/" class="flex items-center justify-center bg-[#373737]/20 border border-white/10 rounded-2xl px-5 sm:px-6 py-2.5">
                <img src={logo.src} alt="Wizz Financial" class="h-8 sm:h-9 object-contain" />
              </a>
              <a
                href="/dashboard"
                class="flex items-center gap-2 font-medium text-white bg-[#4D4222]/25 border border-white/10 px-5 sm:px-6 py-3 rounded-[2.5rem] whitespace-nowrap text-sm sm:text-base"
              >
                Explore WIZZ
                <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M6 3L11 8L6 13" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <Carousel />
    <PageAnimations />
  </body>
</html>
