---
import "../styles/global.css";
import LogoCard from "../components/LogoCard.astro";
import PageAnimations from "../components/PageAnimations.astro";
import Carousel from "../components/Carousel.astro";
import banner from "../assets/ApplicationBanner.png";
import mapdots from "../assets/Mapdots.png";
import slide1 from "../assets/Slide_1.png";
import slide3 from "../assets/Slide_3.png";
import crossborder from "../assets/Crossborder.png";
import migrant from "../assets/Migrant.png";
import whitecoller from "../assets/Whitecoller.png";
import bankfintech from "../assets/Bankfintech.png";
import smecorparate from "../assets/Smecorparate.png";
import logo from "../assets/Wizzlogo.png";

const stats = [
  { value: "5Mn+",   label: "Customers" },
  { value: "50+",    label: "Regulatory Licences" },
  { value: "500+",   label: "Physical Branches" },
  { value: "159",    label: "Countries Payout Network" },
  { value: "$6.9Bn", label: "Transaction Volumes*" },
];

// Extend this array to add more carousel slides
const slides = [
  {
    title: "The Only Platform Focusing on GCC, INDIA, SEA & US Corridors",
    p2: "Wizz Financial connects cross-border payments, digital wallets, card issuing, secured lending, and stablecoin treasury on a single regulated infrastructure — built for the corridors that matter most.",
    fgImage: slide1.src,
    fgAlt: "Wizz platform visualization",
  },
  {
    title: "Serving Every Cross-Border Customer",
    p2: "Legacy systems break across borders — creating friction, delays, and high costs for global customers. Wizz Financial solves this with an integrated financial stack built specifically for cross-border scale.",
    bgImage: mapdots.src,
    fgImage: "",
    fgAlt: "",
    fgScale: "",
    cards: [
      { image: crossborder.src,  label: "Cross Border Families", style: "top:1%;left:5%"   },
      { image: migrant.src,      label: "Migrant workers",       style: "top:32%;left:36%" },
      { image: whitecoller.src,  label: "White Collar Expats",   style: "top:3%;right:3%"  },
      { image: bankfintech.src,  label: "Banks & Fintechs",      style: "top:70%;left:8%"  },
      { image: smecorparate.src, label: "SME & Corporates",      style: "top:65%;right:3%" },
    ],
  },
  {
    title: "The Financial Operating System for Cross-Border Populations",
    p2: "Wizz Financial is a regulated financial ecosystem with licensed credibility across the GCC, India, South East Asia, and the US.",
    bgImage: mapdots.src,
    fgImage: slide3.src,
    fgAlt: "Wizz platform layers",
    fgScale: "scale-100",
    listItems: [
      {
        title: "Core Platform",
        subtitle: "Zero Assumption | Cloud-native | API Gateway",
      },
      {
        title: "Treasury",
        subtitle: "Stable coin-backed Treasury Bypass | Traditional Treasury",
      },
      {
        title: "Processing Engine",
        subtitle:
          "Processing Engine | KYC | KYB | KYBC | KYT | AML | AI/ML | Authentication & Authorisation for VISA & Mastercard",
      },
      {
        title: "Connectivity",
        subtitle: "Bank APIs | Payment Networks | External Services",
      },
      {
        title: "Distribution",
        subtitle:
          "B2C: Wallet, Card, Stablecoin, Agents, Branch, Kiosk | B2B APIs, FIs",
      },
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logo.src} />
    <title>Landing Page</title>
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <div
      style={`background-image: url('${banner.src}')`}
      class="relative min-h-screen w-full bg-cover bg-center bg-no-repeat flex flex-col p-5 sm:p-8 md:p-10 lg:p-12"
    >
      <div class="absolute inset-0 bg-[#12152F]/50"></div>

      <div
        class="relative z-10 flex-1 flex flex-col justify-between gap-8 sm:gap-10 lg:gap-0"
      >
        <!-- Sub-header -->
        <div
          class="opacity-0 flex flex-col gap-5 mb-10 h-fit sm:flex-row sm:justify-between sm:items-center lg:mb-0"
          data-animate="fade-up"
          data-delay="100"
        >
          <LogoCard />
          <a
            href="/dashboard"
            class="flex items-center text-lg justify-center gap-2 whitespace-nowrap cursor-pointer
      font-medium text-white bg-[#4D4222]/30
      w-52 h-16 rounded-[2.5rem]"
          >
            Explore WIZZ

            <svg
              class="w-4 h-4"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M6 3L11 8L6 13"
                stroke="white"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>

        <!-- Carousel -->
        <div
          id="carousel"
          class="opacity-0 relative"
          data-animate="fade-up"
          data-delay="300"
        >
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <!-- Left: per-slide text panels, absolutely stacked -->
            <div
              class="lg:col-span-6 relative
              min-h-44 sm:min-h-56 md:min-h-72 lg:min-h-80 xl:min-h-88 2xl:min-h-96"
            >
              {
                slides.map((slide, i) => (
                  <div
                    class={`carousel-slide absolute inset-0 flex flex-row gap-6 items-center transition-opacity duration-300 ease-in-out ${i === 0 ? "opacity-100" : "opacity-0 pointer-events-none"}`}
                    data-slide={i}
                  >
                    <div
                      class="shrink-0 rounded-full bg-linear-to-b from-[#F6AF27] to-[#CA7D0F]
                      w-1.5  h-40
                      sm:w-2  sm:h-52
                      md:w-2.5 md:h-64
                      lg:w-3  lg:h-72
                      xl:w-3.5 xl:h-80
                      2xl:w-4  2xl:h-80"
                    />

                    <div
                      class="flex-1 bg-[#373737]/30 border border-white/10 rounded-3xl
                    p-3 sm:p-4 md:p-5 lg:p-6 xl:p-8"
                    >
                      <h2
                        class="text-white font-bold leading-16 mb-5 md:mb-6 
                        text-lg sm:text-2xl md:text-3xl lg:text-3xl xl:text-4xl 2xl:text-5xl"
                      >
                        {slide.title}
                      </h2>
                      <div>
                        <p
                          class="text-[#CBCBCB] font-light md:leading-8
                          text-xs sm:text-sm md:text-base lg:text-lg xl:text-xl 2xl:text-xl"
                        >
                          {slide.p2}
                        </p>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- Right: per-slide content (slide 1 = Slide_1 only, others = mapdots + overlays) -->
            <div class="lg:col-span-6 relative min-h-80 sm:min-h-96 md:min-h-[420px] lg:min-h-[480px] xl:min-h-[540px]">
              {
                slides.map((slide, i) =>
                  "cards" in slide ? (
                    <div
                      data-fg={i}
                      class={`absolute inset-0 w-full h-full transition-opacity duration-300 ease-in-out
                      ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      <img
                        src={mapdots.src}
                        alt=""
                        aria-hidden="true"
                        class="w-full h-full object-cover"
                      />
                      {slide.cards!.map((card: { image: string; label: string; style: string }) => (
                        <div
                          class="absolute flex flex-col items-center gap-3 rounded-2xl bg-[#1c2748]/65 backdrop-blur-2xl border border-white/15 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08),0_8px_32px_rgba(0,0,0,0.4)] p-4 w-[28%]"
                          style={card.style}
                        >
                          <img src={card.image} alt={card.label} class="w-full h-24 object-contain" />
                          <span class="text-white text-sm text-center leading-tight font-medium">{card.label}</span>
                        </div>
                      ))}
                    </div>
                  ) : "listItems" in slide ? (
                    <div
                      data-fg={i}
                      class={`absolute inset-0 w-full h-full z-10 flex flex-col lg:flex-row items-center
                      transition-opacity duration-300 ease-in-out
                      ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      <img
                        src={mapdots.src}
                        alt=""
                        aria-hidden="true"
                        class="absolute inset-0 w-full h-full object-cover"
                      />
                      <div class="relative z-10 flex flex-col lg:flex-row items-center w-full h-full">
                        <img
                          src={slide.fgImage}
                          alt={slide.fgAlt}
                          class="w-64 h-[500px] object-contain ml-32"
                        />
                        <div class="flex-1 flex flex-col max-w-xs">
                          {slide.listItems!.map(
                            (
                              item: { title: string; subtitle: string },
                              idx: number,
                            ) => (
                              <div
                                class={`py-1.5 lg:py-2 xl:py-2.5 ${idx < slide.listItems!.length - 1 ? "border-b border-white/10" : ""}`}
                              >
                                <h3
                                  class="text-white font-bold mb-0.5"
                                  style="font-size:20px"
                                >
                                  {item.title}
                                </h3>
                                <p
                                  class="text-[#CBCBCB] font-light leading-relaxed"
                                  style="font-size:14px"
                                >
                                  {item.subtitle}
                                </p>
                              </div>
                            ),
                          )}
                        </div>
                      </div>
                    </div>
                  ) : (
                    /* Slide 1: Slide_1 image (smaller) + stats cards below */
                    <div
                      data-fg={i}
                      class={`absolute inset-0 w-full h-full flex flex-col gap-3 transition-opacity duration-300 ease-in-out
                      ${i === 0 ? "opacity-100" : "opacity-0"}`}
                    >
                      <img
                        src={slide.fgImage}
                        alt={slide.fgAlt}
                        class="w-full object-contain"
                        style="height: 70%"
                      />
                      <div class="flex flex-row mt-12" style="gap:16px">
                        {stats.map((stat) => (
                          <div class="flex-1 flex flex-col items-center justify-center gap-1 bg-[#1c2748]/65 backdrop-blur-sm border border-white/10 rounded-xl p-3 lg:p-4">
                            <span class="text-white font-bold text-base lg:text-xl xl:text-2xl text-center">{stat.value}</span>
                            <span class="text-[#CBCBCB] text-xs font-light leading-snug text-center">{stat.label}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  ),
                )
              }
            </div>
          </div>
        </div>

        <!-- Footer: dot indicators -->
        <div
          class="opacity-0 flex justify-start"
          data-animate="fade-up"
          data-delay="700"
        >
          <div
            class="flex flex-row items-center gap-2 bg-[#373737]/12 rounded-full p-2"
          >
            <!-- Chevron left -->
            <button
              type="button"
              aria-label="Previous slide"
              data-prev
              class="flex items-center justify-center text-white/70 hover:text-white cursor-pointer border-0 bg-transparent transition-colors duration-200"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M10 3L5 8L10 13"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>

            <!-- Dots -->
            <div
              role="tablist"
              aria-label="Carousel navigation"
              class="flex flex-row items-center gap-2"
            >
              {
                slides.map((_, i) => (
                  <button
                    type="button"
                    role="tab"
                    aria-label={`Go to slide ${i + 1}`}
                    aria-selected={i === 0 ? "true" : "false"}
                    data-dot={i}
                    class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer border-0 ${i === 0 ? "active" : "bg-white/40 hover:bg-white/70"}`}
                    style={i === 0 ? "background-color:#BA7F4A" : ""}
                  />
                ))
              }
            </div>

            <!-- Chevron right -->
            <button
              type="button"
              aria-label="Next slide"
              data-next
              class="flex items-center justify-center text-white/70 hover:text-white cursor-pointer border-0 bg-transparent transition-colors duration-200"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M6 3L11 8L6 13"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <Carousel />
    <PageAnimations />
  </body>
</html>
