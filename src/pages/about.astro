---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/MainFooter.astro";
import PageAnimations from "../components/PageAnimations.astro";
import BrandCard from "../components/BrandCard.astro";
import banner from "../assets/ApplicationBanner.png";
import logo from "../assets/Wizzlogo.png";
import zlogo from "../assets/Zlogo.png";
import brand1 from "../assets/Brand1.png";
import brand2 from "../assets/Brand2.png";
import brand3 from "../assets/Brand3.png";
import brand4 from "../assets/Brand4.png";
import brand5 from "../assets/Brand5.png";
import brand6 from "../assets/Brand6.png";
import wizzBrand1 from "../assets/Wizz-Brand1.png";
import wizzBrand2 from "../assets/Wizz-Brand2.png";
import wizzBrand3 from "../assets/Wizz-Brand3.png";
import wizzBrand4 from "../assets/Wizz-Brand4.png";
import wizzBrand5 from "../assets/Wizz-Brand5.png";
import wizzBrand6 from "../assets/Wizz-Brand6.png";
import earth from "../assets/Earth.png";
import visionImg from "../assets/Vision_about.png";
import missionImg from "../assets/Mission_about.png";
import differImg from "../assets/Differ_about.png";


const corridorTabs = [
  { label: "India to Rest of the World", selected: true },
  { label: "USA to Rest of The World ", selected: false },
  { label: "UAE to Rest of the World", selected: false },
  { label: "Coverage Map", selected: false },
];

const brandCards = [
  {
    image: brand1.src,
    imageAlt: "Brand 1",
    badgeLogo: wizzBrand1.src,
    badgeLogoAlt: "Wizz Brand 1",
  },
  {
    image: brand2.src,
    imageAlt: "Brand 2",
    badgeLogo: wizzBrand2.src,
    badgeLogoAlt: "Wizz Brand 2",
  },
  {
    image: brand3.src,
    imageAlt: "Brand 3",
    badgeLogo: wizzBrand3.src,
    badgeLogoAlt: "Wizz Brand 3",
  },
  {
    image: brand4.src,
    imageAlt: "Brand 4",
    badgeLogo: wizzBrand4.src,
    badgeLogoAlt: "Wizz Brand 4",
  },
  {
    image: brand5.src,
    imageAlt: "Brand 5",
    badgeLogo: wizzBrand5.src,
    badgeLogoAlt: "Wizz Brand 5",
  },
  {
    image: brand6.src,
    imageAlt: "Brand 6",
    badgeLogo: wizzBrand6.src,
    badgeLogoAlt: "Wizz Brand 6",
  },
];

const visionMissionCards = [
  {
    title: "The Vision",
    text: "Build the financial operating system for cross-border populations – a single platform that works wherever the customer lives, travels, sends, or borrows.",
    image: visionImg.src,
    imageAlt: "Vision",
  },
  {
    title: "The Mission",
    text: "Deliver seamless, secure, and compliant financial services independent of traditional banking rails – combining physical accessibility with digital innovation.",
    image: missionImg.src,
    imageAlt: "Mission",
  },
  {
    title: "The Differentiation",
    text: "Unlike pure digital fintechs that lack physical reach, or traditional banks with poor UX – WizzFinancial is the only hybrid platform with both regulatory infrastructure and street-level distribution.",
    image: differImg.src,
    imageAlt: "Differentiation",
  },
];

const partnerColumns = [
  {
    title: "Payment Network",
    partners: [
      { name: "Visa", description: "In Principal Global Member" },
      { name: "UPI", description: "Direct UPI integration for india payments" },
      { name: "RuPay", description: "Card scheme: 1st AED denominates" },
      { name: "Bharat BillPay", description: "Bill payments across India" },
    ],
  },
  {
    title: "Banking Partners",
    partners: [
      { name: "Airtel Payments Bank", description: "Distribution Partner" },
      { name: "HDFC Bank", description: "AD I partner in india" },
      { name: "Yes Bank", description: "AD I Partner In india" },
      { name: "FAB", description: "HNW1 Product" },
    ],
  },
  {
    title: "Tech & More Partners",
    partners: [
      { name: "BitGo", description: "Stablecoin rail for B2C remittances" },
      { name: "IndiGo", description: "Travel Partners" },
      { name: "AWS", description: "Amazon-AWS" },
      { name: "Samsung", description: "Samsung" },
    ],
  },
];

const problemPills = [
  "Regulatory complexity",
  "Fragmented systems",
  "Multiple intermediaries",
  "High fees",
  "Multi-day settlement",
  "Outdated technology",
  "Lack of transparency",
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logo.src} />
    <title>About</title>
    <style define:vars={{ bannerSrc: `url('${banner.src}')` }}>
      .hero-bg {
        background-image: var(--bannerSrc);
      }
    </style>
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <div
      class="hero-bg relative min-h-screen w-full bg-cover bg-center bg-no-repeat"
    >
      <div class="absolute inset-0 bg-[#12152F]/50"></div>

      <div
        class="relative z-10 flex flex-col justify-between gap-10 sm:gap-14 md:gap-24 lg:gap-34 p-5 sm:p-8 md:p-10 lg:p-12"
      >
        <!-- Header -->
        <div class="opacity-0" data-animate="fade-up" data-delay="100">
          <Header />
        </div>

        <!-- Section 1: Hero intro -->
        <div
          class="opacity-0 flex flex-col items-center md:gap-6 gap-3"
          data-animate="fade-up"
          data-delay="200"
        >
          <img
            src={zlogo.src}
            alt="Wizz Z logo"
            class="w-24 h-24 md:w-24 md:h-24 object-contain"
          />

          <h1
            class="text-white font-bold text-center text-3xl md:text-5xl lg:text-5xl"
          >
            About Us
          </h1>

          <h2 class="text-white font-bold text-center text-xl md:text-2xl">
            The Problem Seen
          </h2>

          <!-- Scrollable problem pills -->
          <div
            class="w-full flex overflow-x-auto gap-6 py-2 justify-start md:justify-center"
            style="scrollbar-width: none; -ms-overflow-style: none;"
          >
            {
              problemPills.map((pill) => (
                <div class="flex-shrink-0 px-5 py-2 rounded-full border border-white/20 bg-[#4D4222]/40 text-white text-[18px] whitespace-nowrap">
                  {pill}
                </div>
              ))
            }
          </div>

          <p
            class="text-white/80 text-center leading-relaxed max-w-5xl text-sm sm:text-base md:text-lg mt-2"
          >
            India, GCC and Asia are tightly linked, yet financial services are
            fragmented, slow &amp; expensive. 280M global migrants move $800B+
            annually through fragmented, expensive, slow channels – paying 5-8%
            in fees and waiting days for settlement. <br />
            <strong
              >No single platform serves them across origin and destination
              countries.</strong
            >
          </p>

          <!-- Vision / Mission / Differentiation cards -->
          <div class="w-full grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
            {
              visionMissionCards.map((card) => (
                <div
                  class="relative overflow-hidden rounded-2xl bg-[#373737]/30 border border-white/10 min-h-[300px]
                  transition-all duration-500 ease-in-out hover:bg-white/10 hover:border-white/20 hover:scale-[1.02]"
                >
                  <div class="flex flex-col gap-3 p-6 pb-3 z-10 relative">
                    <h3 class="text-white font-bold text-[20px]">
                      {card.title}
                    </h3>
                    <p class="text-white/70 text-sm md:text-base leading-relaxed">
                      {card.text}
                    </p>
                  </div>
                  <img
                    src={card.image}
                    alt={card.imageAlt}
                    class="absolute -bottom-[30px] -right-[50px] w-[200px] h-[200px] object-contain opacity-90 pointer-events-none"
                  />
                </div>
              ))
            }
          </div>
        </div>

        <!-- Section 2: Wizz Financial Brands -->
        <div
          class="opacity-0 flex flex-col gap-3"
          data-animate="fade-up"
          data-delay="300"
        >
          <h2
            class="text-white font-bold text-2xl sm:text-3xl md:text-4xl leading-tight"
          >
            Wizz Financial Brands
          </h2>
          <p
            class="text-white/60 text-base sm:text-lg md:text-xl leading-relaxed"
          >
            Our dynamic brands include
          </p>

          <!-- Brand cards grid -->
          <div
            class="md:mt-10 mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full pb-8"
          >
            {
              brandCards.map((card) => (
                <BrandCard
                  image={card.image}
                  imageAlt={card.imageAlt}
                  badgeLogo={card.badgeLogo}
                  badgeLogoAlt={card.badgeLogoAlt}
                />
              ))
            }
          </div>
        </div>

        <!-- Section 3: Tier-1 Partner Ecosystem -->
        <div
          class="opacity-0 flex flex-col md:items-center md:justify-center justify-start md:text-center md:gap-6 gap-3"
          data-animate="fade-up"
          data-delay="400"
        >
          <div class="flex flex-col md:items-center md:gap-4 gap-2">
            <h2
              class="text-white font-bold text-2xl sm:text-3xl md:text-4xl leading-tight text-left md:text-center"
            >
              Tier-1 Partner Ecosystem
            </h2>
          </div>
          <p
            class="text-white/60 text-base sm:text-lg md:text-xl leading-relaxed max-w-4xl"
          >
            We’re proud to partner with some of the best in the business to enhance our capabilities and extend our offering across India, the GCC and Africa. Find a full list of our partners below:
          </p>

          <!-- Partner Ecosystem Grid -->
          <div class="w-full grid grid-cols-1 sm:grid-cols-3 gap-8 mt-8 text-left">
            {
              partnerColumns.map((col) => (
                <div class="flex flex-col gap-4 bg-[#373737]/20 border border-white/10 rounded-2xl p-5">
                  <h3 class="text-white font-bold text-xl md:text-2xl">{col.title}</h3>
                  <div class="flex flex-col gap-10 mt-6">
                    {col.partners.map((partner) => (
                      <div class="flex items-center gap-4">
                        <div class="w-[72px] h-[72px] flex-shrink-0 rounded-xl bg-white flex items-center justify-center">
                          <!-- logo placeholder -->
                        </div>
                        <p class="text-white/80 text-sm md:text-base leading-snug">{partner.description}</p>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Section 4: Corridors and Markets -->
        <div
          class="opacity-0 flex flex-col md:items-center md:justify-center md:text-center md:gap-6 gap-3"
          data-animate="fade-up"
          data-delay="500"
        >
          <div class="flex flex-col md:items-center gap-4">
            <h2
              class="text-white font-bold text-2xl sm:text-3xl md:text-4xl leading-tight"
            >
              Corridors and Markets
            </h2>
          </div>
          <p
            class="text-white/60 text-base sm:text-lg md:text-xl leading-relaxed max-w-4xl"
          >
            Wizz connects the GCC and the US as primary send regions with India
            and Southeast Asia as core receive and two‑way growth markets. This
            footprint places us at the centre of the most important global
            remittance corridors, linking advanced‑economy senders with some of
            the largest remittance‑receiving markets worldwide.
          </p>

          <!-- Corridors Tabs -->
          <div
            class="md:mt-10 mt-4 flex overflow-x-auto gap-4 w-full justify-center"
          >
            {
              corridorTabs.map((tab) => (
                <div
                  class={`corridor-tab px-6 py-2 rounded-full text-base w-fit flex-shrink-0 transition-all duration-300 cursor-pointer border
                  ${
                    tab.selected
                      ? "bg-[#FFBD00]/17 border-[#F79A59] text-white"
                      : "bg-[#8A8A8A]/10 text-white hover:bg-white/10 border-transparent"
                  }`}
                >
                  {tab.label}
                </div>
              ))
            }
          </div>

          <!-- Map Card -->
          <div
            class="md:mt-10 mt-5 w-full bg-[#373737]/30 border border-white/10 rounded-[10px] md:p-10 md:h-auto h-[400px]"
          >
            <img
              src={earth.src}
              alt="Corridors Map"
              class="w-full md:h-auto h-full md:object-contain object-cover rounded-md"
            />
          </div>
        </div>

        <!-- Footer -->
        <div class="opacity-0" data-animate="fade-up" data-delay="600">
          <Footer />
        </div>
      </div>
    </div>

    <PageAnimations />

    <script>
      function setupTabs() {
        const tabs = document.querySelectorAll(".corridor-tab");

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            // Reset all tabs to inactive state
            tabs.forEach((t) => {
              t.classList.remove("bg-[#FFBD00]/17", "border-[#F79A59]");
              t.classList.add("bg-[#8A8A8A]/10", "border-transparent");
            });

            // Set clicked tab to active state
            tab.classList.remove("bg-[#8A8A8A]/10", "border-transparent");
            tab.classList.add("bg-[#FFBD00]/17", "border-[#F79A59]");
          });
        });
      }

      // Setup tabs functionality
      setupTabs();
    </script>
  </body>
</html>
