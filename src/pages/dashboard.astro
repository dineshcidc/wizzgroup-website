---
// Dashboard — /dashboard
// Placeholder until Figma design is implemented
import Header from "../components/Header.astro";
import TabCard from "../components/TabCard.astro";
import banner from "../assets/ApplicationBanner.png";
import logo from "../assets/Wizzlogo.png";
import zlOgoCopacity from "../assets/zlogo-opacity.png";
import globalImage from "../assets/Global.png";
import GccImage from "../assets/Gcc.png";
import IndiaSEAImage from "../assets/India & SEA.png";
import UsaImage from "../assets/Usa.png";
import RestOfWorldImage from "../assets/Rest of World.png";
import B2CRemittancesImg from "../assets/B2C Remittances.png";
import ForeignExchangeImg from "../assets/Foreign Exchange.png";
import B2BRemittancesImg from "../assets/B2B Remittances.png";
import WPSSalaryPayoutsImg from "../assets/WPS Salary payouts.png";
import FXPrepaidCardsImg from "../assets/FX Prepaid Cards.png";
import BillPaymentsImg from "../assets/Bill Payments.png";
import AssetBackedLendingImg from "../assets/Asset - Backed Lending.png";
import RemitNowPayLaterImg from "../assets/Remit Now Pay Later.png";
import InsurancePremiumFinanceImg from "../assets/Insurance Premium Finance.png";
import EducationLoansImg from "../assets/Education Loans.png";
import ProprietaryCoreImg from "../assets/Proprietary Core.png";
import AIPoweredDecisioningImg from "../assets/AI-powered decisioning.png";
import CloudNativeAPIImg from "../assets/Cloud-native & API.png";
import CardIssueImg from "../assets/Card Issue.png";
import StablecoinImg from "../assets/Stablecoin.png";
import facebook from "../assets/Facebook.png";
import instagram from "../assets/Instagram.png";
import telegram from "../assets/Telegram.png";
import linkedin from "../assets/Linkedin.png";
import chatbotAI from "../assets/Chatbot-AI.png";
import infrastructureAI from "../assets/Infrastructure AI.png";
import backendAI from "../assets/Backend.png";
import frontendAI from "../assets/Frontend.png";

import "../styles/global.css";
import PageAnimations from "../components/PageAnimations.astro";
import MainFooter from "../components/MainFooter.astro";

// Tab Content Data
const tabContent = {
  payments: {
    title: "Cross Border Payments",
    cards: [
      { label: "B2C Remittances", image: B2CRemittancesImg.src, hoverText: "Businesses sending money directly to customers, like refunds or payouts." },
      { label: "Foreign Exchange", image: ForeignExchangeImg.src, hoverText: "Converting one country's currency into another for international transactions." },
      { label: "B2B Remittances", image: B2BRemittancesImg.src, hoverText: "Businesses sending payments to other businesses for goods or services." },
      { label: "WPS Salary payouts", image: WPSSalaryPayoutsImg.src, hoverText: "Employers paying salaries through regulated systems to ensure timely employee payments." },
      { label: "FX Prepaid Cards", image: FXPrepaidCardsImg.src, hoverText: "Preloaded cards for spending in foreign currencies while traveling abroad." },
      { label: "Bill Payments", image: BillPaymentsImg.src, hoverText: "Paying utility or service bills like electricity, water, or internet." },
    ],
  },
  lending: {
    title: "Secured Lending",
    cards: [
      { label: "Asset - Backed Lending", image: AssetBackedLendingImg.src },
      { label: "Remit Now Pay Later", image: RemitNowPayLaterImg.src },
      { label: "Insurance Premium Finance", image: InsurancePremiumFinanceImg.src },
      { label: "Education Loans", image: EducationLoansImg.src },
    ],
  },
};

const presenceImageData = {
  gcc: GccImage.src,
  "india & sea": IndiaSEAImage.src,
  usa: UsaImage.src,
  "rest of the world": RestOfWorldImage.src,
};

const faqItems = [
  {
    question: "What services does Wizz Financial offer?",
    answer:
      "Wizz Financial is your partner for tailored financial services. We specialize in personal loans for your needs and business financing to fuel your ambitions. Our investment advisory offers guidance to maximize returns and minimize risks.",
  },
  {
    question: "How do I apply for a loan?",
    answer:
      "You can apply for a loan online through our platform. Complete the application, upload the required documents, and our team will review your request quickly to help you access funds sooner.",
  },
  {
    question: "What documents are required for loan approval?",
    answer:
      "Typically we require proof of identity, proof of address, income statements, and any business-related paperwork if you are applying for a business loan. Exact requirements depend on the loan type.",
  },
  {
    question: "How long does the approval process take?",
    answer:
      "Approval times vary based on the loan type and documentation provided, but most approvals are completed within a few business days once your application is complete.",
  },
  {
    question: "Is my personal and financial information secure?",
    answer:
      "Yes. We use industry-standard security measures to safeguard your information and protect your privacy throughout the loan application and servicing process.",
  },
];
---

<html lang="en">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href={logo.src} />
  <title>Dashboard</title>
  <style define:vars={{ bannerSrc: `url('${banner.src}')` }}>
    .hero-bg {
      background-image: var(--bannerSrc);
    }

    details[open] summary .faq-chevron {
      transform: rotate(180deg);
    }

    .faq-panel {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transform: translateY(-8px);
      transition:
        max-height 0.35s ease,
        opacity 0.3s ease,
        transform 0.3s ease;
    }

    details[open] .faq-panel {
      max-height: 1000px;
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <body class="m-0 p-0 overflow-x-hidden">
    <div
      class="hero-bg relative min-h-screen w-full bg-cover bg-center bg-no-repeat"
    >
      <div class="absolute inset-0 bg-[#12152F]/50"></div>

      <div
        class="relative z-10 flex flex-col justify-between gap-10 sm:gap-14 md:gap-16 lg:gap-24 p-5 sm:p-8 md:p-10 lg:p-12"
      >
        <!-- Header -->
        <div class="opacity-0 z-50" data-animate="fade-up" data-delay="100">
          <Header />
        </div>

        <!-- Section 1: Hero intro -->
        <div
          class="opacity-0 flex md:flex-row flex-col justify-between w-full md:items-center gap-6"
          data-animate="fade-up"
          data-delay="200"
        >
          <h1
            class="order-2 md:order-1 text-white font-bold text-start lg:leading-tight md:leading-10 text-md sm:text-2xl md:text-2xl xl:text-6xl"
          >
            Transforming Payments & Lending In <br /> <span class="text-[#E87E51]">Growth Markets</span>
          </h1>

            <div class="order-1 md:order-2 flex flex-row gap-4 items-center">
              <div
                class="cursor-pointer hover:transform hover:-translate-y-2 transition-transform duration-300"
              >
                <img src={facebook.src} alt="Facebook" class="w-8 h-8" />
              </div>
              <div
                class="cursor-pointer hover:transform hover:-translate-y-2 transition-transform duration-300"
              >
                <img src={instagram.src} alt="Instagram" class="w-8 h-8" />
              </div>
              <div
                class="cursor-pointer hover:transform hover:-translate-y-2 transition-transform duration-300"
              >
                <img src={telegram.src} alt="Telegram" class="w-8 h-8" />
              </div>
              <div
                class="cursor-pointer hover:transform hover:-translate-y-2 transition-transform duration-300"
              >
                <img src={linkedin.src} alt="Linkedin" class="w-8 h-8" />
              </div>
          </div>
        </div>

        <!-- Section 2: Grid Layout (6/6 columns) -->
        <div
          class="opacity-0 w-full grid grid-cols-1 lg:grid-cols-2 gap-12"
          data-animate="fade-up"
          data-delay="300"
        >
          <!-- Left Column (6 columns) -->
          <div class="flex flex-col gap-0" id="payments-section">
            <TabCard
              title="Our Financial Capabilities"
              buttonLabel="Read More"
              tabs={[
                { label: "Cross Border Payments", selected: true },
                { label: "Secured Lending", selected: false },
                { label: "Technology Infrastructure", selected: false },
              ]}
              backgroundImage={zlOgoCopacity.src}
            />

            <!-- Vertical connector: moves under whichever tab is active (positioned by dashboard-payments.js) -->
            <div class="relative w-full h-14">
              <div id="tab-connector" class="absolute flex flex-col items-center" style="left: 0; transform: translateX(-50%); transition: left 0.3s ease;">
                <div class="w-px h-12 bg-gradient-to-b from-[#BA7F4A]/30 to-[#BA7F4A]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#BA7F4A]"></div>
              </div>
            </div>

            <div class="relative overflow-hidden w-full bg-[#373737]/30 rounded-xl md:p-6 p-3 flex flex-col flex-1">
              <!-- Decorative top-right glow -->
              <div class="absolute -top-20 -left-8 w-72 h-72 rounded-full bg-[#E5AF1C]/15 blur-[85px] pointer-events-none"></div>

              <div id="payments-content" class="flex flex-col flex-1" style="transition: opacity 0.25s ease;">
              <h2
                id="card-title"
                class="bg-gradient-to-r from-[#959595] to-[#B1D1EA] bg-clip-text text-transparent text-xl sm:text-2xl font-normal mb-6"
              >
                {tabContent.payments.title}
              </h2>

              <div
                id="cards-container"
                class="grid grid-cols-2 md:gap-6 gap-3 content-start flex-1"
              >
                {
                  tabContent.payments.cards.slice(0, 4).map((card) => (
                    <div class="relative group flex flex-col items-center justify-center text-center md:flex-row md:justify-between md:text-left gap-3 bg-[#373737]/12 border border-white/10 rounded-xl p-3 md:p-5 min-h-28 md:min-h-34 transition duration-300 hover:bg-[#474747]/20">
                      <span class="text-white text-xs md:text-base">
                        {card.label}
                      </span>
                      <img
                        src={card.image}
                        alt={card.label}
                        class="h-12 md:h-16 xl:h-24 w-auto object-contain"
                      />
                      <div class="hidden md:flex absolute right-4 md:right-5 top-1/2 -translate-y-1/2 z-10 w-60 flex-col gap-1 text-left bg-[#3F3F3F]/75 backdrop-blur-md border border-white/20 rounded-xl p-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                        <span class="text-white text-base font-medium leading-tight">{card.label}</span>
                        <span class="text-white/75 text-sm leading-snug">{card.hoverText}</span>
                      </div>
                    </div>
                  ))
                }
              </div>
              </div>

              <div class="flex justify-end mt-8">
                <div
                  class="flex items-center gap-3 bg-[#373737]/30 border border-white/10 rounded-full p-2"
                >
                  <svg
                    id="payments-prev"
                    class="w-4 h-4 text-white cursor-pointer"
                    viewBox="0 0 16 16"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M10 3L5 8L10 13"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>

                  <div id="payments-dots" class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full cursor-pointer bg-[#BA7F4A]"></span>
                    <span class="w-2 h-2 rounded-full cursor-pointer bg-white/40"></span>
                  </div>

                  <svg
                    id="payments-next"
                    class="w-4 h-4 text-white cursor-pointer"
                    viewBox="0 0 16 16"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M6 3L11 8L6 13"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column (6 columns) -->
          <div class="flex flex-col gap-0" id="presence-section">
            <TabCard
              title="Our Presence"
              buttonLabel="Read More"
              tabs={[
                { label: "GCC", selected: true },
                { label: "India & SEA", selected: false },
                { label: "USA", selected: false },
                { label: "Rest of the World", selected: false },
              ]}
              backgroundImage={globalImage.src}
            />

            <!-- Vertical connector: moves under whichever presence tab is active (positioned by dashboard-presence.js) -->
            <div class="relative w-full h-14">
              <div id="presence-connector" class="absolute flex flex-col items-center" style="left: 0; transform: translateX(-50%); transition: left 0.3s ease;">
                <div class="w-px h-12 bg-gradient-to-b from-[#BA7F4A]/30 to-[#BA7F4A]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#BA7F4A]"></div>
              </div>
            </div>

            <div class="relative overflow-hidden w-full bg-[#373737]/30 rounded-xl md:p-6 p-3 flex flex-col flex-1">
              <!-- Decorative top-left glow -->
              <div class="absolute -top-20 -left-8 w-72 h-72 rounded-full bg-[#E5AF1C]/15 blur-[85px] pointer-events-none"></div>

              <div
                class="relative md:h-[400px] h-[300px] flex items-end justify-center overflow-visible"
              >
                <img
                  id="presence-image"
                  src={GccImage.src}
                  alt="GCC"
                  class="h-100 w-auto md:object-cover object-contain absolute -bottom-12"
                  style="transition: opacity 0.25s ease;"
                />
              </div>

              <div class="flex justify-end mt-auto md:pt-8 pt-4">
                <div
                  class="flex items-center gap-3 bg-[#373737]/30 border border-white/10 rounded-full p-2"
                >
                  <svg
                    class="w-4 h-4 text-white"
                    viewBox="0 0 16 16"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M10 3L5 8L10 13"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>

                  <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-[#BA7F4A]"></span>
                    <span class="w-2 h-2 rounded-full bg-white/40"></span>
                  </div>

                  <svg
                    class="w-4 h-4 text-white"
                    viewBox="0 0 16 16"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M6 3L11 8L6 13"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Stats row -->
        <div class="opacity-0 w-full" data-animate="fade-up" data-delay="400">
          <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-6">
            {
              [
                { count: "5Mn+", label: "Customers Served" },
                { count: "200+", label: "Countries Covered" },
                { count: "900k", label: "Agent Network" },
                { count: "400+", label: "Worldwide Locations" },
              ].map((item) => (
                <div class="flex flex-col items-center justify-center gap-3 rounded-3xl p-8 text-center">
                  <span class="text-[#FAA819] text-3xl sm:text-4xl font-semibold leading-none">
                    {item.count}
                  </span>
                  <span class="text-white text-base sm:text-lg leading-snug max-w-45">
                    {item.label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Section 4: AI Stack -->
        <div class="opacity-0 w-full" data-animate="fade-up" data-delay="500">
          <div
            class="relative flex lg:flex-row flex-col gap-5 items-center border border-white/10 rounded-2xl overflow-visible bg-white/5 md:p-6 p-4 xl:p-8"
          >
            <!-- Robot character — overflows top and bottom -->
            <div
              class="flex-shrink-0 relative -my-10 w-36 sm:w-52 md:w-64 xl:w-80"
            >
              <img
                src={chatbotAI.src}
                alt="AI Robot"
                class="w-full h-auto object-contain drop-shadow-2xl"
              />
            </div>

            <!-- Right content wrapper: #919191 at 20% opacity, 24px padding -->
            <div class="flex-1 min-w-0 rounded-4xl bg-[#919191]/10 backdrop-blur-md border border-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] md:p-8 p-4">
              <h2
                class="text-white xl:text-[32px] md:text-xl font-medium leading-snug mb-6"
              >
                All Across the Entire Stack,{" "}
                <strong class="font-bold">AI isn't a feature.</strong><br />
                It's embedded in every layer
              </h2>

              <!-- Three AI cards -->
              <div class="grid grid-cols-1 sm:grid-cols-3 xl:gap-8 gap-3 items-stretch">
                <div
                  class="flex flex-row items-center gap-3 sm:flex-col sm:items-center bg-[#373737]/30 border border-white/5 rounded-xl xl:p-5 p-3 sm:text-center flex-1"
                >
                  <img
                    src={infrastructureAI.src}
                    alt="Infrastructure AI"
                    class="h-14 w-14 sm:h-40 sm:w-40 object-contain flex-shrink-0"
                  />
                  <div class="flex flex-col gap-1 sm:items-center">
                    <span class="text-white font-bold text-sm md:text-md xl:text-xl">Infrastructure AI</span>
                    <span class="text-white/55 text-xs xl:text-base leading-snug">Engineer &amp; Coding</span>
                  </div>
                </div>

                <div
                  class="flex flex-row items-center gap-3 sm:flex-col sm:items-center bg-[#373737]/24 border border-white/5 rounded-xl xl:p-5 p-3 sm:text-center flex-1"
                >
                  <img
                    src={backendAI.src}
                    alt="Backend"
                    class="h-14 w-14 sm:h-40 sm:w-40 object-contain flex-shrink-0"
                  />
                  <div class="flex flex-col gap-1 sm:items-center">
                    <span class="text-white font-bold text-sm md:text-md xl:text-xl">Backend</span>
                    <span class="text-white/55 text-xs xl:text-base leading-snug">KYC/KYB | Treasury |<br />Risk &amp; Underwriting</span>
                  </div>
                </div>

                <div
                  class="flex flex-row items-center gap-3 sm:flex-col sm:items-center bg-[#373737]/24 border border-white/5 rounded-xl xl:p-5 p-3 sm:text-center flex-1"
                >
                  <img
                    src={frontendAI.src}
                    alt="Frontend"
                    class="h-14 w-14 sm:h-40 sm:w-40 object-contain flex-shrink-0"
                  />
                  <div class="flex flex-col gap-1 sm:items-center">
                    <span class="text-white font-bold text-sm md:text-md xl:text-xl">Frontend</span>
                    <span class="text-white/55 text-xs xl:text-base leading-snug">UX-Agentic AI |<br />Speech AI</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 5: FAQ -->
        <div class="opacity-0 w-full" data-animate="fade-up" data-delay="450">
          <div class="flex flex-col gap-10">
            <h2 class="text-white text-3xl sm:text-4xl font-bold">
              Frequently Asked Questions (Faq)
            </h2>
            <div class="flex flex-col gap-6">
              {
                faqItems.map((item, index) => (
                  <details
                    class="group rounded-xl border border-white/10 bg-[#1F1F1F]/50 overflow-hidden"
                    open={index === 0}
                  >
                    <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-white text-base sm:text-lg font-medium list-none">
                      <span class="block bg-gradient-to-r from-[#959595] to-[#B1D1EA] bg-clip-text text-transparent">
                        {item.question}
                      </span>
                      <span class="faq-chevron transition-transform duration-300 text-white">
                        <svg
                          class="w-5 h-5"
                          viewBox="0 0 16 16"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                          aria-hidden="true"
                        >
                          <path
                            d="M6 5L10 8L6 11"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </span>
                    </summary>
                    <div class="faq-panel px-6 pb-5 text-white/75 text-md leading-7">
                      {item.answer}
                    </div>
                  </details>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="opacity-0" data-animate="fade-up" data-delay="600">
          <MainFooter />
        </div>
      </div>
      <PageAnimations />

      <!--
        Expose server-side asset URLs as a global so the client scripts below can read them.
        window.DASHBOARD_IMAGES is consumed by dashboard-payments.js and dashboard-presence.js.
      -->
      <script
        define:vars={{
          GccImage: GccImage.src,
          IndiaSEAImage: IndiaSEAImage.src,
          UsaImage: UsaImage.src,
          RestOfWorldImage: RestOfWorldImage.src,
          B2CRemittances: B2CRemittancesImg.src,
          ForeignExchange: ForeignExchangeImg.src,
          B2BRemittances: B2BRemittancesImg.src,
          WPSSalaryPayouts: WPSSalaryPayoutsImg.src,
          FXPrepaidCards: FXPrepaidCardsImg.src,
          BillPayments: BillPaymentsImg.src,
          AssetBackedLending: AssetBackedLendingImg.src,
          RemitNowPayLater: RemitNowPayLaterImg.src,
          InsurancePremiumFinance: InsurancePremiumFinanceImg.src,
          EducationLoans: EducationLoansImg.src,
          ProprietaryCore: ProprietaryCoreImg.src,
          AIPoweredDecisioning: AIPoweredDecisioningImg.src,
          CloudNativeAPI: CloudNativeAPIImg.src,
          CardIssue: CardIssueImg.src,
          Stablecoin: StablecoinImg.src,
        }}
      >
        window.DASHBOARD_IMAGES = {
          gcc: GccImage,
          indiaSea: IndiaSEAImage,
          usa: UsaImage,
          restOfWorld: RestOfWorldImage,
          b2cRemittances: B2CRemittances,
          foreignExchange: ForeignExchange,
          b2bRemittances: B2BRemittances,
          wpsSalaryPayouts: WPSSalaryPayouts,
          fxPrepaidCards: FXPrepaidCards,
          billPayments: BillPayments,
          assetBackedLending: AssetBackedLending,
          remitNowPayLater: RemitNowPayLater,
          insurancePremiumFinance: InsurancePremiumFinance,
          educationLoans: EducationLoans,
          proprietaryCore: ProprietaryCore,
          aiPoweredDecisioning: AIPoweredDecisioning,
          cloudNativeApi: CloudNativeAPI,
          cardIssue: CardIssue,
          stablecoin: Stablecoin,
        };
      </script>

      <!--
        Section 2 (Left Column)  → src/scripts/dashboard-payments.js
        Section 2 (Right Column) → src/scripts/dashboard-presence.js
      -->
      <script>
        import { setupPaymentsSection } from "../scripts/dashboard-payments.js";
        import { setupPresenceSection } from "../scripts/dashboard-presence.js";

        declare global {
          interface Window {
            DASHBOARD_IMAGES: Record<string, string>;
          }
        }

        setupPaymentsSection(window.DASHBOARD_IMAGES);
        setupPresenceSection(window.DASHBOARD_IMAGES);
      </script>
    </div>
  </body>
</html>
