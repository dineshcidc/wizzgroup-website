---
import Header from "../components/Header.astro";
import Footer from "../components/MainFooter.astro";
import PageAnimations from "../components/PageAnimations.astro";
import banner from "../assets/ApplicationBanner.png";
import logo from "../assets/Wizzlogo.png";
import heroImage from "../assets/Blog2.png";

import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logo.src} />
    <title>Newsroom Detail</title>
    <style define:vars={{ bannerSrc: `url('${banner.src}')` }}>
      .hero-bg {
        background-image: var(--bannerSrc);
      }
    </style>
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <div class="hero-bg relative w-full bg-cover bg-center bg-no-repeat">
      <div class="absolute inset-0 bg-[#12152F]/50"></div>

      <div
        class="relative z-10 flex flex-col justify-between gap-10 sm:gap-14 md:gap-24 lg:gap-34 p-5 sm:p-8 md:p-10 lg:p-12"
      >
        <!-- Header -->
        <div class="opacity-0" data-animate="fade-up" data-delay="100">
          <Header />
        </div>

        <!-- Breadcrumb + Image + Content -->
        <div class="flex flex-col md:gap-15 gap-8">
          <!-- Breadcrumb -->
          <div
            class="opacity-0 flex flex-col gap-4"
            data-animate="fade-up"
            data-delay="150"
          >
            <nav class="flex items-center gap-2 text-sm text-white/60">
              <a
                href="/newsroom"
                class="hover:text-white transition-colors duration-200">Newsroom</a
              >
              <span class="text-white/40">/</span>
              <span class="text-white/90">Press Release</span>
            </nav>
            <hr class="w-full border-0 h-px bg-white/20" />
          </div>

          <!-- Hero Image -->
          <div
            class="opacity-0 w-full rounded-2xl overflow-hidden"
            data-animate="fade-up"
            data-delay="200"
          >
            <img
              src={heroImage.src}
              alt="Wizz Financial Completes First Stablecoin-Powered Cross-Border Payment"
              class="w-full h-72 sm:h-96 md:h-120 xl:h-180 object-cover"
            />
          </div>

          <!-- Content: Date+Title (left) + Article Body (right) -->
          <div
            class="opacity-0 grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-8 md:gap-12"
            data-animate="fade-up"
            data-delay="300"
          >
            <!-- Left: Date + Title -->
            <div class="flex flex-col gap-4">
              <!-- Date -->
              <div
                class="flex items-center gap-2 text-white/60 text-sm bg-[#8A8A8A]/30 rounded-full px-4 py-2 w-fit"
              >
                <svg
                  class="w-4 h-4 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <rect
                    x="3"
                    y="4"
                    width="18"
                    height="18"
                    rx="3"
                    stroke="currentColor"
                    stroke-width="1.5"></rect>
                  <path
                    d="M3 9H21"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"></path>
                  <path
                    d="M8 2V6M16 2V6"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"></path>
                </svg>
                <span>December 2025</span>
              </div>

              <!-- Title -->
              <h1
                class="text-2xl md:text-3xl xl:text-5xl font-bold text-white leading-snug"
              >
                Wizz Financial Completes First Stablecoin-Powered Cross-Border Payment
              </h1>
            </div>

            <!-- Right: Article Body -->
            <div
              class="bg-[#373737]/50 rounded-xl md:p-5 p-3 flex flex-col gap-5 text-white/80 text-sm  md:text-xl xl:text-2xl lg:leading-10 leading-6"
            >
              <p>
                <span class="font-semibold text-white">Wizz Financial</span> has
                completed its first stablecoin-powered cross-border remittance and
                treasury transaction originating from the United States, marking a
                significant milestone in the company's multi-product fintech platform.
              </p>

              <p>
                The transaction extended Wizz CrossBorder USA capabilities into
                blockchain-based B2B and B2C payments, with reach into over 80
                countries. This was carried out in collaboration with BitGo's
                digital trust bank, utilizing BitGo's wallet infrastructure and
                eTrade services.
              </p>

              <p>
                This milestone reflects Wizz Financial's commitment to building
                the infrastructure for the next generation of cross-border
                financial services — combining speed, transparency, and global
                accessibility through blockchain-enabled technology.
              </p>

              <p>
                The company continues to expand its footprint across key
                corridors, reinforcing its position as a leading fintech
                innovator in the cross-border payments space.
              </p>
            </div>
          </div>

          <!-- Footer -->
          <div class="opacity-0" data-animate="fade-up" data-delay="400">
            <Footer />
          </div>
        </div>
      </div>

      <PageAnimations />
    </div>
  </body>
</html>
