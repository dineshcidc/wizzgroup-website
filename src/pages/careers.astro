---
import Header from "../components/Header.astro";
import Footer from "../components/MainFooter.astro";
import PageAnimations from "../components/PageAnimations.astro";
import banner from "../assets/ApplicationBanner.png";
import logo from "../assets/Wizzlogo.png";

import "../styles/global.css";

const tabs = [
  { label: "All Positions", selected: true },
  { label: "Development", selected: false },
  { label: "Designing", selected: false },
  { label: "Testing", selected: false },
];

const jobs = [
  {
    title: "Website Developer",
    description:
      "We are looking for a driven website developer to become a part of our talented team. This role offers a fantastic opportunity to contribute to existing projects and gives you the chance to shape your own role.",
    badges: [
      { icon: "location", label: "Hybrid (Remote + On-site)" },
      { icon: "clock", label: "Full Time" },
    ],
    category: "Development",
  },
  {
    title: "Graphic Designer",
    description:
      "Join our creative team as a graphic designer to craft visually compelling designs across digital and print media, enhancing brand identity and user engagement.",
    badges: [
      { icon: "location", label: "Hybrid (Remote + On-site)" },
      { icon: "clock", label: "Part Time" },
    ],
    category: "Designing",
  },
  {
    title: "Data Analyst",
    description:
      "Seeking a detail-oriented data analyst to interpret complex datasets, generate actionable insights, and support strategic decision-making processes.",
    badges: [
      { icon: "location", label: "On-site" },
      { icon: "clock", label: "Full Time" },
    ],
    category: "Development",
  },
  {
    title: "Content Strategist",
    description:
      "We need a content strategist to develop and manage engaging content plans that drive traffic, enhance SEO, and strengthen brand messaging.",
    badges: [
      { icon: "location", label: "100% Remote" },
      { icon: "clock", label: "Contract" },
    ],
    category: "Designing",
  },
  {
    title: "QA Engineer",
    description:
      "We are looking for a detail-oriented QA engineer to design and execute test plans, identify bugs, and ensure our products meet the highest quality standards before release.",
    badges: [
      { icon: "location", label: "Hybrid (Remote + On-site)" },
      { icon: "clock", label: "Full Time" },
    ],
    category: "Testing",
  },
  {
    title: "Automation Test Engineer",
    description:
      "Join our QA team to build and maintain automated test suites, improve test coverage, and integrate testing pipelines into our CI/CD workflows.",
    badges: [
      { icon: "location", label: "100% Remote" },
      { icon: "clock", label: "Full Time" },
    ],
    category: "Testing",
  },
  {
    title: "Performance Test Analyst",
    description:
      "Seeking a performance test analyst to conduct load, stress, and scalability testing across our platforms, ensuring reliability under peak traffic conditions.",
    badges: [
      { icon: "location", label: "On-site" },
      { icon: "clock", label: "Contract" },
    ],
    category: "Testing",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logo.src} />
    <title>Careers</title>
    <style define:vars={{ bannerSrc: `url('${banner.src}')` }}>
      .hero-bg {
        background-image: var(--bannerSrc);
      }
    </style>
  </head>
  <body class="m-0 p-0 overflow-x-hidden">
    <div
      class="hero-bg relative min-h-screen w-full bg-cover bg-center bg-no-repeat"
    >
      <div class="absolute inset-0 bg-[#12152F]/50"></div>

      <div
        class="relative z-10 flex flex-col justify-between gap-10 sm:gap-14 md:gap-24 lg:gap-34 p-5 sm:p-8 md:p-10 lg:p-12 min-h-screen"
      >
        <!-- Header -->
        <div class="opacity-0" data-animate="fade-up" data-delay="100">
          <Header />
        </div>

        <!-- Hero Title Section -->
        <div
          class="opacity-0 flex flex-col items-center justify-center md:gap-6 gap-3 text-center px-4"
          data-animate="fade-up"
          data-delay="200"
        >
          <h1
            class="text-white font-bold text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-tight max-w-3xl"
          >
            Be a Part of Our Mission
          </h1>

          <p
            class="text-white/70 text-sm sm:text-base md:text-xl leading-relaxed max-w-4xl"
          >
            We are looking for passionate people to join us on a mission. We
            value a flat hierarchy, clear mission, full ownership, and
            responsibility.
          </p>
        </div>

        <!-- Job Listings Section -->
        <div
          class="opacity-0 flex flex-col gap-6"
          data-animate="fade-up"
          data-delay="300"
        >
          <!-- Tabs -->
          <div class="flex overflow-x-auto gap-3 w-full">
            {
              tabs.map((tab) => (
                <div
                  class={`career-tab px-6 py-2 rounded-full text-sm sm:text-base w-fit flex-shrink-0 transition-all duration-300 cursor-pointer border
                  ${
                    tab.selected
                      ? "bg-[#FFBD00]/17 border-[#F79A59] text-white"
                      : "bg-[#8A8A8A]/10 text-white hover:bg-white/10 border-transparent"
                  }`}
                  data-category={tab.label}
                >
                  {tab.label}
                </div>
              ))
            }
          </div>

          <!-- Divider below tabs -->
          <hr class="w-full border-0 h-px bg-white/20" />

          <!-- Job Cards -->
          <div class="flex flex-col gap-4 md:mt-10 mt-5" id="job-list">
            {
              jobs.map((job) => (
                <div
                  class="job-card flex items-center justify-between gap-6 bg-[#1F1F1F]/60 border border-white/10 rounded-2xl p-5 sm:p-6 lg:p-8 transition-all duration-300 hover:bg-white/10 hover:border-white/20 cursor-pointer"
                  data-category={job.category}
                >
                  <!-- Left: Info -->
                  <div class="flex flex-col gap-3 flex-1 min-w-0">
                    <h3 class="text-white font-semibold text-base sm:text-lg lg:text-xl">
                      {job.title}
                    </h3>
                    <p class="text-white/60 text-xs sm:text-sm leading-relaxed line-clamp-2">
                      {job.description}
                    </p>
                    <!-- Badges -->
                    <div class="flex flex-wrap gap-2 mt-1">
                      {job.badges.map((badge) => (
                        <div class="flex items-center gap-1.5 bg-[#8A8A8A]/20 rounded-full px-4 py-2">
                          {badge.icon === "location" ? (
                            <svg
                              class="w-3.5 h-3.5 text-white/60 shrink-0"
                              viewBox="0 0 24 24"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path
                                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                              <circle
                                cx="12"
                                cy="9"
                                r="2.5"
                                stroke="currentColor"
                                stroke-width="1.5"
                              />
                            </svg>
                          ) : (
                            <svg
                              class="w-3.5 h-3.5 text-white/60 shrink-0"
                              viewBox="0 0 24 24"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <circle
                                cx="12"
                                cy="12"
                                r="9"
                                stroke="currentColor"
                                stroke-width="1.5"
                              />
                              <path
                                d="M12 7v5l3 3"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          )}
                          <span class="text-white/70 text-xs">{badge.label}</span>
                        </div>
                      ))}
                    </div>
                  </div>

                  <!-- Right: Chevron -->
                  <div class="shrink-0 w-9 h-9 rounded-full border border-white/20 flex items-center justify-center transition-all duration-300 hover:border-white/50">
                    <svg
                      class="w-4 h-4 text-white"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M9 18L15 12L9 6"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Footer -->
        <div class="opacity-0" data-animate="fade-up" data-delay="400">
          <Footer />
        </div>
      </div>
    </div>

    <PageAnimations />

    <script>
      function setupCareerTabs() {
        const tabs = document.querySelectorAll<HTMLElement>(".career-tab");
        const cards = document.querySelectorAll<HTMLElement>(".job-card");

        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            // Update active tab style
            tabs.forEach((t) => {
              t.classList.remove("bg-[#FFBD00]/17", "border-[#F79A59]");
              t.classList.add("bg-[#8A8A8A]/10", "border-transparent");
            });
            tab.classList.remove("bg-[#8A8A8A]/10", "border-transparent");
            tab.classList.add("bg-[#FFBD00]/17", "border-[#F79A59]");

            const selected = tab.dataset.category ?? "All Positions";

            // Filter cards
            cards.forEach((card) => {
              if (
                selected === "All Positions" ||
                card.dataset.category === selected
              ) {
                card.style.display = "flex";
              } else {
                card.style.display = "none";
              }
            });
          });
        });
      }

      setupCareerTabs();
    </script>
  </body>
</html>
