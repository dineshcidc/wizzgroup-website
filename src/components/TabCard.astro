---
interface Props {
  title: string;
  tabs: Array<{
    label: string;
    selected: boolean;
  }>;
  buttonLabel?: string;
  buttonOnClick?: string;
  backgroundImage?: string;
}

const {
  title,
  tabs,
  buttonLabel = "View More",
  buttonOnClick = "",
  backgroundImage,
} = Astro.props;
---

<div
  class="tab-card relative bg-[#373737]/50 border border-white/10 rounded-xl p-4 transition-all duration-300 overflow-hidden"
>
  <!-- Background Image Layer -->
  {
    backgroundImage && (
      <img
        src={backgroundImage}
        alt=""
        class="absolute right-0 top-0 md:h-48 h-16 md:w-48 w-16 object-cover pointer-events-none"
        aria-hidden="true"
      />
    )
  }

  <!-- Content Layer -->
  <div class="relative z-10">
    <!-- Top Section: Title and Button -->
    <div class="flex items-center justify-between mb-6">
      <!-- Left side: Title -->
      <h3 class="text-white font-medium xl:text-3xl md:text-xl text-sm">
        {title}
      </h3>

      <!-- Right side: Button -->
      <a
        href="/about"
        class="hidden md:flex items-center whitespace-nowrap cursor-pointer
        font-medium text-white
        gap-2 px-6 py-3 rounded-[40px] text-base
        transition-all duration-300 hover:bg-white/10"
      >
        Know more

        <!-- Right chevron -->
        <svg
          class="w-4 h-4"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M6 3L11 8L6 13"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <!-- Below Section: Tabs — horizontal scroll on mobile, wrap on md+ -->
    <div
      class="overflow-x-auto md:overflow-x-visible w-full"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >
      <div class="flex flex-nowrap md:flex-wrap items-stretch gap-3 w-max md:w-full">
        {
          tabs.map((tab) => (
            <div
              class={`tab-item flex-shrink-0 flex items-center justify-center px-8 rounded-full text-[14px] w-fit transition-all duration-300 cursor-pointer border text-center h-[48px]
            ${
              tab.selected
                ? "bg-[#FFBD00]/17 border-[#F79A59] text-white"
                : "bg-[#8A8A8A]/10 text-white hover:bg-white/10 border-transparent"
            }`}
            >
              <Fragment set:html={tab.label} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  function setupTabCardTabs() {
    const tabCards = document.querySelectorAll(".tab-card");

    tabCards.forEach((card) => {
      const tabs = card.querySelectorAll(".tab-item");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          // Reset all tabs to inactive state within this card
          tabs.forEach((t) => {
            t.classList.remove("bg-[#FFBD00]/17", "border-[#F79A59]");
            t.classList.add("bg-[#8A8A8A]/10", "border-transparent");
          });

          // Set clicked tab to active state
          tab.classList.remove("bg-[#8A8A8A]/10", "border-transparent");
          tab.classList.add("bg-[#FFBD00]/17", "border-[#F79A59]");
        });
      });
    });
  }

  // Setup tabs functionality when DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupTabCardTabs);
  } else {
    setupTabCardTabs();
  }
</script>
