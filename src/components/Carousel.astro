<script>
  const slides = document.querySelectorAll<HTMLElement>(".carousel-slide");
  const fgImages = document.querySelectorAll<HTMLElement>("[data-fg]");
  const dots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");
  const FADE_OUT = 350;
  const FADE_IN = 400;
  const AUTO_DELAY = 8000;
  let current = 0;
  let isAnimating = false;
  let autoTimer: ReturnType<typeof setInterval>;

  function updateDots(activeIndex: number): void {
    dots.forEach((dot, i) => {
      const active = i === activeIndex;
      dot.setAttribute("aria-selected", String(active));
      if (active) {
        dot.classList.add("active");
        dot.classList.remove("bg-white/40");
        dot.style.backgroundColor = "#BA7F4A";
      } else {
        dot.classList.remove("active");
        dot.style.backgroundColor = "";
        dot.classList.add("bg-white/40");
      }
    });
  }

  function goToSlide(next: number): void {
    if (next === current || isAnimating) return;
    isAnimating = true;

    const prevIdx = current;

    slides[prevIdx].classList.remove("opacity-100");
    slides[prevIdx].classList.add("opacity-0", "pointer-events-none");
    fgImages[prevIdx].classList.remove("opacity-100");
    fgImages[prevIdx].classList.add("opacity-0");

    setTimeout(() => {
      slides[next].classList.remove("opacity-0", "pointer-events-none");
      slides[next].classList.add("opacity-100");
      fgImages[next].classList.remove("opacity-0");
      fgImages[next].classList.add("opacity-100");

      updateDots(next);
      current = next;

      setTimeout(() => {
        isAnimating = false;
      }, FADE_IN);
    }, FADE_OUT);
  }

  function startAuto(): void {
    autoTimer = setInterval(() => {
      goToSlide((current + 1) % slides.length);
    }, AUTO_DELAY);
  }

  function resetAuto(): void {
    clearInterval(autoTimer);
    startAuto();
  }

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      goToSlide(Number(dot.dataset.dot));
      resetAuto();
    });
  });

  const prevBtn = document.querySelector<HTMLButtonElement>("[data-prev]");
  const nextBtn = document.querySelector<HTMLButtonElement>("[data-next]");

  prevBtn?.addEventListener("click", () => {
    goToSlide((current - 1 + slides.length) % slides.length);
    resetAuto();
  });

  nextBtn?.addEventListener("click", () => {
    goToSlide((current + 1) % slides.length);
    resetAuto();
  });

  startAuto();
</script>
