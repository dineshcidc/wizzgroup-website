---
/**
 * PageAnimations.astro — Reusable page-load animation utility
 *
 * Usage:
 *   import PageAnimations from '../components/PageAnimations.astro';
 *   <PageAnimations />   ← place just before </body>
 *
 * How to animate an element:
 *   Add class="opacity-0" + data-animate="fade-up|fade-in" + data-delay="200"
 *   The script picks these up and applies the correct animation + delay.
 *
 * NOTE: style is:global so animation classes reach elements anywhere on the page.
 */
---

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const targets = document.querySelectorAll<HTMLElement>('[data-animate]');

    targets.forEach((el) => {
      const type  = el.dataset.animate ?? '';
      const delay = el.dataset.delay   ?? '0';

      // Remove Tailwind's opacity-0 and add the animation simultaneously.
      // The animation's own "from { opacity: 0 }" handles the hidden state,
      // so there is no visible flash between removal and animation start.
      el.classList.remove('opacity-0');
      if (type === 'fade-up') el.classList.add('anim-fade-up');
      if (type === 'fade-in') el.classList.add('anim-fade-in');

      // Apply delay
      if (delay !== '0') {
        el.classList.add(`anim-delay-${delay}`);
      }
    });
  });
</script>
