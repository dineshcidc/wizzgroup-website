---
/**
 * LogoCard.astro — Reusable branded card component
 *
 * Responsive breakpoints:
 *   base/sm  → mobile  (~375–639px)
 *   md       → tablet  (768px+)
 *   lg       → small desktop (1024px+)
 *   xl       → desktop (1280px+)
 *   2xl      → large desktop (1536px+) — original design size
 */
import logo from '../assets/Wizzlogo.png';
---

<div
  class="flex items-center justify-between bg-[#373737]/12
    w-full h-16 p-3 rounded-4xl border border-white/10
    sm:h-16 sm:p-3 sm:rounded-[36px]
    md:w-72 md:h-16 md:p-3 md:rounded-[36px]
    lg:w-80 lg:h-18 lg:p-4 lg:rounded-[40px]
    xl:w-110 xl:h-20 xl:p-5 xl:rounded-[52px]
    2xl:w-125 2xl:h-24 2xl:p-6 2xl:rounded-[56px]"
>
  <!-- Left: Logo — scales with card height -->
  <a href="/">
    <img
      src={logo.src}
      alt="Wizzgroup Logo"
      class="object-contain
        h-6
        sm:h-7
        md:h-8
        lg:h-9
        xl:h-10
        2xl:h-11"
    />
  </a>

  <!-- Right: Explore button -->
  <a
    href="/dashboard"
    class="flex items-center whitespace-nowrap cursor-pointer
      font-medium text-white bg-[#4D4222]/40
      gap-1 h-8 px-3 py-1 rounded-[20px] text-base
      sm:gap-1.5 sm:h-8 sm:px-3 sm:py-1 sm:rounded-[22px] sm:text-xs
      md:gap-2 md:h-9 md:px-4 md:py-1.5 md:rounded-[26px] md:text-sm
      lg:gap-2 lg:h-10 lg:px-4 lg:py-2 lg:rounded-[30px] lg:text-sm
      xl:gap-2 xl:h-11 xl:px-5 xl:py-2 xl:rounded-[36px] xl:text-sm
      2xl:gap-2 2xl:h-12.5 2xl:px-6 2xl:py-2.5 2xl:rounded-[40px] 2xl:text-base"
  >
    Explore WIZZ

    <!-- Right chevron — scales with button text size -->
    <svg
      class="w-3 h-3 sm:w-3 sm:h-3 md:w-3.5 md:h-3.5 lg:w-4 lg:h-4 xl:w-4 xl:h-4 2xl:w-4 2xl:h-4"
      viewBox="0 0 16 16"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        d="M6 3L11 8L6 13"
        stroke="white"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>
</div>
