---
/**
 * LogoCard.astro — Reusable branded card component
 *
 * Responsive breakpoints:
 *   base/sm  → mobile  (~375–639px)
 *   md       → tablet  (768px+)
 *   lg       → small desktop (1024px+)
 *   xl       → desktop (1280px+)
 *   2xl      → large desktop (1536px+) — original design size
 */
import logo from "../assets/Wizzlogo.png";
---

<div
  class="flex items-center justify-center bg-[#373737]/12 border border-white/10
    w-full rounded-xl p-8
    sm:w-44 sm:rounded-2xl
    md:w-52 md:rounded-3xl
    lg:w-44 lg:rounded-3xl lg:p-5
    xl:w-52 xl:rounded-3xl xl:p-6"
>
  <a href="/">
    <img
      src={logo.src}
      alt="Wizzgroup Logo"
      class="object-contain
        h-12
        sm:h-14
        md:h-16
        lg:h-12
        xl:h-16"
    />
  </a>
</div>
