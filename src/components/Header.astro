---
/**
 * Header.astro — Site-wide header component
 */
import logo from "../assets/Wizzlogo.png";
---

<div class="relative w-full z-50">
  <header
    class="w-full flex items-center justify-between bg-[#373737]/10 border border-white/10
      p-3 rounded-xl
      sm:p-3
      md:p-4
      lg:p-4
      xl:p-5
      2xl:p-6"
  >
    <!-- Left: Logo -->
    <a href="/">
      <img
        src={logo.src}
        alt="Wizzgroup Logo"
        class="object-contain
        h-7
        sm:h-8
        md:h-9
        lg:h-10
        xl:h-11
        2xl:h-12"
      />
    </a>

    <!-- Right: Contact Us button + Menu icon -->
    <div class="flex items-center gap-5">
      <!-- Contact Us button -->
      <button
        type="button"
        class="flex items-center whitespace-nowrap cursor-pointer
          font-medium text-white bg-[#4D4222]/40
          gap-1 h-8 px-3 py-1 rounded-[20px] text-xs
          sm:gap-1.5 sm:h-8 sm:px-3 sm:py-1 sm:rounded-[22px] sm:text-xs
          md:gap-2 md:h-9 md:px-4 md:py-1.5 md:rounded-[26px] md:text-sm
          lg:gap-2 lg:h-10 lg:px-4 lg:py-2 lg:rounded-[30px] lg:text-sm
          xl:gap-2 xl:h-11 xl:px-5 xl:py-2 xl:rounded-[36px] xl:text-sm
          2xl:gap-2 2xl:h-12.5 2xl:px-6 2xl:py-2.5 2xl:rounded-[40px] 2xl:text-base"
      >
        Contact Us
        <svg
          class="w-3 h-3 md:w-3.5 md:h-3.5 lg:w-4 lg:h-4"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M6 3L11 8L6 13"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      <!-- Menu toggle button -->
      <button
        id="menu-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="relative cursor-pointer text-white w-6 h-6 md:w-7 md:h-7 flex items-center justify-center"
      >
        <!-- Hamburger icon -->
        <svg
          id="icon-open"
          class="absolute transition-all duration-300 ease-in-out opacity-100 rotate-0"
          width="100%"
          height="100%"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M3 6h18M3 12h18M3 18h18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>

        <!-- Close (X) icon -->
        <svg
          id="icon-close"
          class="absolute transition-all duration-300 ease-in-out opacity-0 rotate-90"
          width="100%"
          height="100%"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M18 6L6 18M6 6l12 12"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </header>

  <!-- Dropdown menu card -->
  <div
    id="nav-menu"
    class="absolute right-0 mt-3 w-56
      bg-[#1F1F1F]/90 backdrop-blur-md border border-white/10 rounded-2xl
      transition-all duration-300 ease-in-out"
    style="opacity:0; transform:translateY(-12px); pointer-events:none;"
  >
    <nav class="flex flex-col p-2">
      {
        [
          { label: "About Us", href: "/about" },
          { label: "Knowledge Center", href: "/knowledge-center" },
          { label: "Careers", href: "/careers" },
          { label: "Newsroom", href: "/newsroom" },
        ].map((item) => (
          <a
            href={item.href}
            class="flex items-center justify-between px-4 py-3 rounded-xl text-sm text-white/80
            hover:text-white hover:bg-white/8 transition-all duration-200 group"
          >
            {item.label}
            <svg
              class="w-4 h-4 text-white/30 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-white/60"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M9 18L15 12L9 6"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
        ))
      }
    </nav>
  </div>
</div>

<script>
  function setupMenu() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("nav-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    if (!toggle || !menu || !iconOpen || !iconClose) return;

    // Reassign to new consts so TypeScript treats all as non-null
    const btn = toggle;
    const panel = menu;
    const open = iconOpen;
    const close = iconClose;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      btn.setAttribute("aria-expanded", "true");

      open.classList.remove("opacity-100", "rotate-0");
      open.classList.add("opacity-0", "rotate-90");
      close.classList.remove("opacity-0", "rotate-90");
      close.classList.add("opacity-100", "rotate-0");

      panel.style.opacity = "1";
      panel.style.transform = "translateY(0)";
      panel.style.pointerEvents = "auto";
    }

    function closeMenu() {
      isOpen = false;
      btn.setAttribute("aria-expanded", "false");

      open.classList.remove("opacity-0", "rotate-90");
      open.classList.add("opacity-100", "rotate-0");
      close.classList.remove("opacity-100", "rotate-0");
      close.classList.add("opacity-0", "rotate-90");

      panel.style.opacity = "0";
      panel.style.transform = "translateY(-12px)";
      panel.style.pointerEvents = "none";
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      isOpen ? closeMenu() : openMenu();
    });

    document.addEventListener("click", (e) => {
      if (
        isOpen &&
        e.target instanceof Node &&
        !panel.contains(e.target) &&
        !btn.contains(e.target)
      ) {
        closeMenu();
      }
    });
  }

  setupMenu();
</script>
